#!/bin/bash
#PBS -l ngpus=2
#PBS -l ncpus=16
#PBS -l walltime=48:00:00
#PBS -q workq@e5-cse-cbgpu01.eecscl.psu.edu
#PBS -N vllm-serve
#PBS -M bvt5283@psu.edu
#PBS -m bea

# ─── vLLM Model Server ───────────────────────────────────────────────────────
# Serves a model via OpenAI-compatible API on port 8000.
#
# Usage:
#   qsub scripts/serve_vllm.pbs
#   MODEL=Qwen/Qwen2.5-0.5B-Instruct qsub scripts/serve_vllm.pbs
# ──────────────────────────────────────────────────────────────────────────────

export PATH="/scratch/$USER/anaconda3/bin:/scratch/$USER/anaconda3/condabin:$PATH"
eval "$(/usr/local/anaconda3/bin/conda shell.bash hook)"
conda activate agentic-carbon

MODEL="${MODEL:-meta-llama/Llama-3.1-8B-Instruct}"
TP="${TP:-1}"
PORT="${PORT:-8000}"

echo "=== Starting vLLM server ==="
echo "Model: $MODEL"
echo "Tensor Parallel: $TP"
echo "Port: $PORT"
echo "Node: $(hostname)"
echo "Time: $(date)"

python -m vllm.entrypoints.openai.api_server \
    --model "$MODEL" \
    --tensor-parallel-size "$TP" \
    --port "$PORT" \
    --api-key "EMPTY" \
    --max-model-len 8192 \
    --enable-auto-tool-choice \
    --tool-call-parser hermes
