#!/bin/bash
#PBS -l ngpus=1
#PBS -l ncpus=8
#PBS -l walltime=12:00:00
#PBS -q workq@e5-cse-cbgpu01.eecscl.psu.edu
#PBS -N vllm-serve
#PBS -M bvt5283@psu.edu
#PBS -m bea

# ─── vLLM Model Server ───────────────────────────────────────────────────────
# Serves a model via OpenAI-compatible API on port 8000.
#
# Usage:
#   qsub scripts/serve_vllm.pbs
#   MODEL=Qwen/Qwen2.5-0.5B-Instruct qsub scripts/serve_vllm.pbs
# ──────────────────────────────────────────────────────────────────────────────

eval "$(/usr/local/anaconda3/bin/conda shell.bash hook)"
conda activate agentic-carbon

export HF_TOKEN="hf_PSZFejUzwVstly emmVugoHjslhAnznQLjO"
export HF_HOME=/scratch/bvt5283/.cache/huggingface
export HF_DATASETS_CACHE=/scratch/bvt5283/.cache/huggingface/datasets

# PBS sets CUDA_VISIBLE_DEVICES to GPU UUIDs; vLLM needs integer indices
# When UUIDs are set, the GPUs are already isolated — just remap to 0,1,...
if [[ "$CUDA_VISIBLE_DEVICES" == *"GPU-"* ]]; then
    NUM_GPUS=$(echo "$CUDA_VISIBLE_DEVICES" | tr ',' '\n' | wc -l)
    echo "PBS assigned GPUs (UUIDs): $CUDA_VISIBLE_DEVICES"
    export CUDA_VISIBLE_DEVICES=$(seq -s ',' 0 $((NUM_GPUS - 1)))
    echo "Remapped to indices: $CUDA_VISIBLE_DEVICES"
fi

MODEL="${MODEL:-meta-llama/Llama-3.1-8B-Instruct}"
TP="${TP:-1}"
PORT="${PORT:-8000}"

echo "=== Starting vLLM server ==="
echo "Model: $MODEL"
echo "Tensor Parallel: $TP"
echo "Port: $PORT"
echo "Node: $(hostname)"
echo "Time: $(date)"

python -m vllm.entrypoints.openai.api_server \
    --model "$MODEL" \
    --tensor-parallel-size "$TP" \
    --port "$PORT" \
    --api-key "EMPTY" \
    --max-model-len 4096 \
    > /scratch/bvt5283/agentic_carbon_characterization/vllm-serve.log 2>&1
