#!/bin/bash
#PBS -l ngpus=2
#PBS -l ncpus=16
#PBS -l walltime=72:00:00
#PBS -l mem=160g
#PBS -q workq@e5-cse-cbgpu01.eecscl.psu.edu
#PBS -N agentic-bench
#PBS -M CHANGE-TO-YOUR-PSU-EMAIL
#PBS -m bea

# ─── Agentic AI Benchmark Runner ─────────────────────────────────────────────
# Runs the full experiment suite.
# NOTE: vLLM must already be serving (submit serve_vllm.pbs first, or run
#       vLLM in the background within this script).
#
# This script:
#   1. Starts vLLM server for the specified model in the background
#   2. Waits for it to be ready
#   3. Runs all experiments
#   4. Kills vLLM server
#   5. Repeats for the second model
# ──────────────────────────────────────────────────────────────────────────────

set -e

SCRATCH="/scratch/$USER"
PROJECT="$SCRATCH/agentic"
export PATH="$SCRATCH/anaconda3/bin:$SCRATCH/anaconda3/condabin:$PATH"
source activate agentic_bench

cd $PROJECT

# ─── Helper: Start vLLM and wait ─────────────────────────────────────────────

start_vllm() {
    local model=$1
    local tp=$2
    local port=${3:-8000}

    echo "=== Starting vLLM: $model (TP=$tp) on port $port ==="
    python -m vllm.entrypoints.openai.api_server \
        --model "$model" \
        --tensor-parallel-size "$tp" \
        --port "$port" \
        --api-key "EMPTY" \
        --max-model-len 8192 \
        --enable-auto-tool-choice \
        --tool-call-parser hermes &
    VLLM_PID=$!

    # Wait for server to be ready (max 5 min)
    echo "Waiting for vLLM to be ready..."
    for i in $(seq 1 60); do
        if curl -s http://localhost:$port/health > /dev/null 2>&1; then
            echo "vLLM ready after ~${i}0 seconds."
            return 0
        fi
        sleep 5
    done
    echo "ERROR: vLLM did not start within 5 minutes."
    kill $VLLM_PID 2>/dev/null
    return 1
}

stop_vllm() {
    if [ -n "$VLLM_PID" ]; then
        echo "Stopping vLLM (PID=$VLLM_PID)..."
        kill $VLLM_PID 2>/dev/null
        wait $VLLM_PID 2>/dev/null
    fi
}

# ─── Model 1: Llama 3.1 8B ──────────────────────────────────────────────────

echo ""
echo "=========================================="
echo "  MODEL 1: Llama-3.1-8B-Instruct"
echo "=========================================="

start_vllm "meta-llama/Llama-3.1-8B-Instruct" 1

export VLLM_BASE_URL="http://localhost:8000/v1"

python runner.py \
    --models llama-8b \
    --reps 3 \
    --output-dir "$PROJECT/results"

stop_vllm

# ─── Model 2: Qwen3.5 0.8B ──────────────────────────────────────────────────

echo ""
echo "=========================================="
echo "  MODEL 2: Qwen3.5-0.8B"
echo "=========================================="

start_vllm "Qwen/Qwen3.5-0.8B" 1

python runner.py \
    --models qwen-0.8b \
    --reps 3 \
    --output-dir "$PROJECT/results"

stop_vllm

# ─── Generate plots ──────────────────────────────────────────────────────────

echo ""
echo "=== Generating analysis plots ==="
python -m analysis.plots

echo ""
echo "=== ALL EXPERIMENTS COMPLETE ==="
echo "Results: $PROJECT/results/"
echo "Figures: $PROJECT/results/figures/"
echo "Time: $(date)"
